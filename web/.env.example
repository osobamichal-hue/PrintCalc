# Proxy v next.config.mjs posílá /api/* na PrintCalc.Api (výchozí port 5281).
# NEXT_PUBLIC_API_BASE_URL nechte prázdné — volání jdou přes stejný origin (localhost:3000).
PRINTCALC_API_ORIGIN=http://localhost:5281

# Pouze pokud API běží na jiné adrese BEZ Next.js proxy:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5281
