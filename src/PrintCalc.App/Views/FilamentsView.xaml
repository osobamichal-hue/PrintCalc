<UserControl x:Class="PrintCalc.App.Views.FilamentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PrintCalc.App.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Language="cs-CZ">
    <UserControl.Resources>
        <converters:DecimalFieldConverter x:Key="DecimalFieldConverter" />
        <converters:StockMovementTypeToCzechConverter x:Key="StockMoveTypeCv" />
        <converters:UtcToLocalDateTimeConverter x:Key="UtcLocalCv" />
    </UserControl.Resources>

    <Border Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F4F8FF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8" CornerRadius="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding WizardStepTitle}" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0" />
                <WrapPanel>
                    <Button Content="1) Skladové karty" Command="{Binding GoToStepCommand}" CommandParameter="0" Style="{StaticResource WizardStepButtonStyle}" />
                    <Button Content="2) Sklad" Command="{Binding GoToStepCommand}" CommandParameter="1" Style="{StaticResource WizardStepButtonStyle}" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,0,0,8">
            <Border Margin="0,0,8,0" Padding="10,8" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Skladové karty" FontSize="12" Foreground="#5C6280" />
                    <TextBlock Text="{Binding Types.Count}" FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,8,0" Padding="10,8" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Skladové položky" FontSize="12" Foreground="#5C6280" />
                    <TextBlock Text="{Binding Stocks.Count}" FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Padding="10,8" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Aktuální krok" FontSize="12" Foreground="#5C6280" />
                    <TextBlock Text="{Binding WizardStepTitle}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <TabControl Grid.Row="2" SelectedIndex="{Binding WizardStepIndex}">
            <TabItem Header="Krok 1 - Skladové karty">
                <DockPanel Margin="0,8,0,0">
                    <Border DockPanel.Dock="Top" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Karta filamentu" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Typ (PLA/PET-G/ASA...)" />
                                    <TextBox Text="{Binding NewTypeName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="Výrobce" />
                                    <TextBox Text="{Binding NewManufacturer, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,0">
                                    <TextBlock Text="Barva" />
                                    <TextBox Text="{Binding NewColor, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,8,0">
                                    <TextBlock Text="Průměr (mm)" />
                                    <TextBox Text="{Binding NewDiameterMm, Converter={StaticResource DecimalFieldConverter}, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,8,0">
                                    <TextBlock Text="Hustota (g/cm3)" />
                                    <TextBox Text="{Binding NewDensityGPerCm3, Converter={StaticResource DecimalFieldConverter}, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <Grid Grid.Row="1" Grid.Column="2" Margin="0,8,8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Tryska min/max (°C)" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Width="60" Margin="0,0,6,0" Text="{Binding NewNozzleTempMinC, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Width="60" Text="{Binding NewNozzleTempMaxC, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Bed min/max (°C)" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Width="60" Margin="0,0,6,0" Text="{Binding NewBedTempMinC, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Width="60" Text="{Binding NewBedTempMaxC, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,8,0">
                                    <TextBlock Text="Poznámky ke kartě" />
                                    <TextBox Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button Content="{Binding SaveTypeButtonText}" Command="{Binding SaveTypeFromFormCommand}" Padding="12,6" Margin="0,0,8,0" />
                                    <Button Content="Vyčistit" Command="{Binding ClearTypeFormCommand}" Padding="12,6" Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                        <WrapPanel>
                            <Button Content="Obnovit" Command="{Binding RefreshCommand}" Padding="12,6" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Uložit změny typů" Command="{Binding SaveTypesCommand}" Padding="12,6" Margin="0,0,8,0" />
                            <Button Content="Smazat vybraný typ" Command="{Binding DeleteTypeCommand}" Padding="12,6" Margin="0,0,8,0" Style="{StaticResource DangerButtonStyle}" />
                            <Button Content="Načíst QR (jpg/png)" Command="{Binding ImportQrImageCommand}" Padding="12,6" Style="{StaticResource SecondaryButtonStyle}" />
                        </WrapPanel>
                    </Border>

                    <Border Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="8">
                        <DataGrid ItemsSource="{Binding Types}"
                                  SelectedItem="{Binding SelectedType}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  MouseDoubleClick="TypesGrid_OnMouseDoubleClick">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Editovat typ" Click="EditType_OnClick" />
                                    <MenuItem Header="Uložit změny typů" Command="{Binding PlacementTarget.DataContext.SaveTypesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Smazat typ" Command="{Binding PlacementTarget.DataContext.DeleteTypeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Název" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTextColumn Header="Výrobce" Binding="{Binding Manufacturer, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTextColumn Header="Barva" Binding="{Binding Color, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                <DataGridTextColumn Header="Ø mm" Binding="{Binding DiameterMm, StringFormat=F2}" Width="70" />
                                <DataGridTextColumn Header="Tryska min °C" Binding="{Binding NozzleTempMinC, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                <DataGridTextColumn Header="Tryska max °C" Binding="{Binding NozzleTempMaxC, UpdateSourceTrigger=PropertyChanged}" Width="95" />
                                <DataGridTextColumn Header="Bed min °C" Binding="{Binding BedTempMinC, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                <DataGridTextColumn Header="Bed max °C" Binding="{Binding BedTempMaxC, UpdateSourceTrigger=PropertyChanged}" Width="85" />
                                <DataGridTextColumn Header="Poznámka" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                <DataGridTextColumn Header="Prům. Kč/kg" Binding="{Binding AveragePricePerKg, StringFormat=F2}" Width="100" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>
            </TabItem>

            <TabItem Header="Krok 2 - Sklad">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                        <WrapPanel>
                            <CheckBox Content="Všechny typy filamentů" IsChecked="{Binding ShowAllStockCards}" Margin="0,0,14,0" VerticalAlignment="Center" />
                            <CheckBox Content="Jen aktivní karty" IsChecked="{Binding ShowOnlyActiveStocks}" Margin="0,0,14,0" VerticalAlignment="Center" />
                            <TextBlock Text="Filtr typu:" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ComboBox Width="260" ItemsSource="{Binding Types}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedType}" />
                            <Button Content="Obnovit" Command="{Binding RefreshCommand}" Margin="12,0,0,0" Padding="12,6" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Příjem na sklad" Command="{Binding OpenReceiveFormCommand}" Padding="12,6" Margin="12,0,8,0" />
                            <Button Content="Výdej ze skladu" Command="{Binding OpenIssueFormFromSelectedStockCommand}" Padding="12,6" />
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="8">
                        <DataGrid ItemsSource="{Binding Stocks}"
                                  SelectedItem="{Binding SelectedStock}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  Margin="0">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Výdej ze skladu..." Command="{Binding PlacementTarget.DataContext.OpenIssueFormFromSelectedStockCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Příjem na sklad..." Command="{Binding PlacementTarget.DataContext.OpenReceiveFormCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Uložit vybranou skladovou kartu" Command="{Binding PlacementTarget.DataContext.SaveSelectedStockCardCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Typ" Binding="{Binding FilamentType.Name}" Width="170" IsReadOnly="True" />
                                <DataGridTextColumn Header="Výrobce" Binding="{Binding FilamentType.Manufacturer}" Width="140" IsReadOnly="True" />
                                <DataGridTextColumn Header="Šarže" Binding="{Binding LotNumber}" Width="120" />
                                <DataGridTextColumn Header="Expirace" Binding="{Binding ExpirationDate, StringFormat=yyyy-MM-dd}" Width="120" />
                                <DataGridTextColumn Header="Dodavatel" Binding="{Binding SupplierName}" Width="*" />
                                <DataGridTextColumn Header="Cena/kg" Binding="{Binding PurchasePricePerKg, StringFormat=F2}" Width="90" />
                                <DataGridTextColumn Header="Počáteční kg" Binding="{Binding InitialWeightKg, StringFormat=F3}" Width="95" />
                                <DataGridTextColumn Header="Zbývá kg" Binding="{Binding RemainingWeightKg, StringFormat=F3}" Width="90" />
                                <DataGridTextColumn Header="Ks" Binding="{Binding PieceCount}" Width="50" />
                                <DataGridTextColumn Header="Naskladněno" Binding="{Binding ReceivedAt, StringFormat=yyyy-MM-dd}" Width="120" IsReadOnly="True" />
                                <DataGridTextColumn Header="Poznámka" Binding="{Binding Notes}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="3" Margin="0,8,0,0" LastChildFill="True">
            <materialDesign:Snackbar DockPanel.Dock="Left"
                                     Width="360"
                                     Message="{Binding StatusMessage}"
                                     IsActive="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToBoolConverter}}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Zpět" Command="{Binding PrevStepCommand}" IsEnabled="{Binding CanGoPrevStep}" Style="{StaticResource WizardNavButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Dále" Command="{Binding NextStepCommand}" IsEnabled="{Binding CanGoNextStep}" Style="{StaticResource WizardNavButtonStyle}" />
            </StackPanel>
        </DockPanel>
    </Grid>
    </Border>
</UserControl>

