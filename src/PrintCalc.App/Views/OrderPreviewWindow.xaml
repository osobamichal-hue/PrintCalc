<Window x:Class="PrintCalc.App.Views.OrderPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Náhled zakázky"
        WindowStartupLocation="CenterOwner"
        Width="980"
        Height="680">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#EA7A2D" Padding="14">
            <TextBlock Text="ZAKAZKA - NAHLED" FontSize="30" Foreground="White" FontWeight="SemiBold" />
        </Border>
        <DockPanel Grid.Row="1" Margin="12">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="{Binding HeaderText}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding DateText}" />
                <TextBlock Text="{Binding TotalText}" FontWeight="SemiBold" />
                <TextBlock Text="ODBĚRATEL" FontWeight="SemiBold" Margin="0,6,0,0" />
                <TextBlock Text="{Binding CustomerText}" TextWrapping="Wrap" />
            </StackPanel>
            <DataGrid ItemsSource="{Binding Lines}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="POLOZKA" Binding="{Binding Description}" Width="*" />
                    <DataGridTextColumn Header="CENA" Binding="{Binding UnitPrice, StringFormat=F2}" Width="110" />
                    <DataGridTextColumn Header="MNOZSTVO" Binding="{Binding Quantity, StringFormat=0.##}" Width="90" />
                    <DataGridTextColumn Header="SPOLU" Binding="{Binding LineTotal, StringFormat=F2}" Width="130" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12">
            <Button Content="Zavřít" IsCancel="True" Padding="12,6" Margin="0,0,8,0" />
            <Button Content="Potvrdit" IsDefault="True" Padding="12,6" Click="Confirm_OnClick" />
        </StackPanel>
    </Grid>
</Window>
