<UserControl x:Class="PrintCalc.App.Views.InvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PrintCalc.App.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <converters:DecimalFieldConverter x:Key="DecimalFieldConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource WizardHeaderBorderStyle}">
            <TextBlock Style="{StaticResource WizardHeaderTextStyle}" Text="Faktury: vyberte a dvojklikem otevřete k editaci." />
        </Border>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left" Text="{Binding WizardStepTitle}" FontWeight="SemiBold" VerticalAlignment="Center" />
            <CheckBox DockPanel.Dock="Right" Content="Kompaktní tabulky" IsChecked="{Binding CompactTables}" VerticalAlignment="Center" Margin="24,0,0,0" />
        </DockPanel>

        <TabControl Grid.Row="2" SelectedIndex="{Binding WizardStepIndex}" Style="{StaticResource WizardTabControlStyle}">
            <TabItem Header="1) Seznam faktur">
                <Grid Margin="0,6,0,0">
                    <DataGrid x:Name="InvoicesGrid"
                              ItemsSource="{Binding Invoices}"
                              SelectedItem="{Binding SelectedInvoice}"
                              RowHeight="{Binding TableRowHeight}"
                              AutoGenerateColumns="False"
                              MouseDoubleClick="InvoicesGrid_OnMouseDoubleClick">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Náhled faktury" Command="{Binding PlacementTarget.DataContext.PreviewSelectedInvoiceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Otevřít k editaci" Command="{Binding PlacementTarget.DataContext.OpenSelectedForEditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Vytvořit ze zakázky" Command="{Binding PlacementTarget.DataContext.FromOrderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Uložit" Command="{Binding PlacementTarget.DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Export PDF" Command="{Binding PlacementTarget.DataContext.ExportPdfCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Export CSV" Command="{Binding PlacementTarget.DataContext.ExportCsvCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Smazat" Command="{Binding PlacementTarget.DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Číslo" Binding="{Binding Number}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Datum" Binding="{Binding IssueDate, StringFormat=yyyy-MM-dd}" Width="110" IsReadOnly="True" />
                    <DataGridTextColumn Header="Splatnost" Binding="{Binding DueDate, StringFormat=yyyy-MM-dd}" Width="110" IsReadOnly="True" />
                    <DataGridTextColumn Header="Platba" Binding="{Binding PaymentMethod}" Width="120" IsReadOnly="True" />
                    <DataGridTemplateColumn Header="Stav" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource DocumentStatusToBrushConverter}}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Celkem" Binding="{Binding TotalAmount, StringFormat=F0}" Width="90" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
                    <Border Background="#DFFFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="16"
                            Visibility="{Binding ElementName=InvoicesGrid, Path=HasItems, Converter={StaticResource BooleanInvertedToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Žádné faktury" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="Vytvořte fakturu ze zakázky." Foreground="Gray" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="2) Položky, náhled a export">
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0">
                        <GroupBox DockPanel.Dock="Top" Header="Přidat položku (formulář)" Margin="0,0,0,8">
                            <WrapPanel Margin="0,4,0,0">
                                <TextBlock Text="Popis:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="250" Text="{Binding NewLineDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                <TextBlock Text="Množství:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="80" Margin="0,0,8,0">
                                    <TextBox.Text>
                                        <Binding Path="NewLineQuantity" Converter="{StaticResource DecimalFieldConverter}" UpdateSourceTrigger="LostFocus" />
                                    </TextBox.Text>
                                </TextBox>
                                <TextBlock Text="Cena/j. bez DPH:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="90" Margin="0,0,8,0">
                                    <TextBox.Text>
                                        <Binding Path="NewLineUnitPrice" Converter="{StaticResource DecimalFieldConverter}" UpdateSourceTrigger="LostFocus" />
                                    </TextBox.Text>
                                </TextBox>
                                <TextBlock Text="DPH %:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="70" Margin="0,0,8,0">
                                    <TextBox.Text>
                                        <Binding Path="NewLineTaxRatePercent" Converter="{StaticResource DecimalFieldConverter}" UpdateSourceTrigger="LostFocus" />
                                    </TextBox.Text>
                                </TextBox>
                                <TextBlock Text="Cena/j. s DPH:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="100" IsReadOnly="True" Text="{Binding NewLineUnitPriceWithVat, Mode=OneWay, StringFormat=F0}" Margin="0,0,8,0" />
                                <TextBlock Text="Řádek bez DPH:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="100" IsReadOnly="True" Text="{Binding NewLineTotalWithoutVat, Mode=OneWay, StringFormat=F0}" Margin="0,0,8,0" />
                                <TextBlock Text="Řádek s DPH:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="100" IsReadOnly="True" Text="{Binding NewLineTotalWithVat, Mode=OneWay, StringFormat=F0}" Margin="0,0,8,0" />
                                <Button Content="Uložit položku" Command="{Binding AddLineCommand}" Padding="10,4" />
                            </WrapPanel>
                        </GroupBox>
                        <DataGrid
                      ItemsSource="{Binding SelectedInvoice.Lines}"
                      SelectedItem="{Binding SelectedInvoiceLine}"
                      RowHeight="{Binding TableRowHeight}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Přidat řádek" Command="{Binding PlacementTarget.DataContext.AddLineCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Odebrat řádek" Command="{Binding PlacementTarget.DataContext.RemoveSelectedInvoiceLineCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Přepočítat a uložit" Command="{Binding PlacementTarget.DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Popis" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    <DataGridTextColumn Header="Množ." Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                    <DataGridTextColumn Header="Cena/j." Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                    <DataGridTextColumn Header="DPH %" Binding="{Binding TaxRatePercent, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                    <DataGridTextColumn Header="Řádek" Binding="{Binding LineTotal, StringFormat=F0}" Width="80" IsReadOnly="True" />
                </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                    <Border Grid.Column="1" Margin="8,0,0,0" BorderBrush="#33000000" BorderThickness="1" CornerRadius="4" Padding="8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Náhled vybrané faktury" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedInvoice.Number, StringFormat=Číslo: {0}}" />
                        <TextBlock Text="{Binding SelectedInvoice.IssueDate, StringFormat=Datum: {0:yyyy-MM-dd}}" />
                        <TextBlock FontWeight="SemiBold">
                            <Run Text="Celkem: " />
                            <Run Text="{Binding SelectedInvoice.TotalAmount, StringFormat={}{0:F0}}" />
                            <Run Text=" " />
                            <Run Text="{Binding CurrencySymbol}" />
                        </TextBlock>
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Řádek" Command="{Binding AddLineCommand}" Margin="0,0,8,0" Padding="10,4" />
                            <Button Content="PDF" Command="{Binding ExportPdfCommand}" Margin="0,0,8,0" Padding="10,4" />
                            <Button Content="CSV" Command="{Binding ExportCsvCommand}" Padding="10,4" />
                        </WrapPanel>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding SelectedInvoice.Lines}" RowHeight="{Binding TableRowHeight}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Položka" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Množ." Binding="{Binding Quantity, StringFormat=0.##}" Width="60" />
                            <DataGridTextColumn Header="Celkem" Binding="{Binding LineTotal, StringFormat=F0}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
                </Grid>
            </TabItem>
            <TabItem Header="3) Nová faktura ze zakázek">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Vyberte zakázky pro fakturu a nastavte parametry." Foreground="Gray" Margin="0,0,0,8" />
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="Řada FA:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox Width="120"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding InvoiceSeriesOptions}"
                                      SelectedItem="{Binding SelectedInvoiceSeries}" />
                            <TextBlock Text="Další číslo:" VerticalAlignment="Center" Margin="12,0,8,0" />
                            <TextBox Width="70"
                                     VerticalAlignment="Center"
                                     Text="{Binding CustomNextInvoiceNumber, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Volitelné: nastaví další číslo v řadě (např. 250 => další bude PREFIX-250 / PREFIX250 podle oddělovače)." />
                            <TextBlock Text="Splatnost (dny):" VerticalAlignment="Center" Margin="12,0,8,0" />
                            <TextBox Width="60"
                                     VerticalAlignment="Center"
                                     Text="{Binding NewInvoiceDueDays, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Platba:" VerticalAlignment="Center" Margin="12,0,8,0" />
                            <ComboBox Width="150"
                                      VerticalAlignment="Center"
                                      IsEditable="True"
                                      ItemsSource="{Binding PaymentMethodOptions}"
                                      Text="{Binding NewInvoicePaymentMethod, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="Detailní převod položek"
                                      IsChecked="{Binding CreateAsDetailedFromOrders}"
                                      VerticalAlignment="Center"
                                      Margin="12,0,0,0" />
                            <Button Content="Vybrat vše" Command="{Binding SelectAllOpenOrdersForInvoiceCommand}" Margin="12,0,8,0" Padding="10,4" />
                            <Button Content="Zrušit výběr" Command="{Binding ClearOpenOrdersForInvoiceCommand}" Margin="0,0,8,0" Padding="10,4" />
                            <TextBlock Text="{Binding SelectedOpenOrdersCountText}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0" />
                            <Button Content="Vytvořit fakturu" Command="{Binding FromOrderCommand}" Padding="12,6" />
                        </WrapPanel>
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding OpenOrderSelections}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              RowHeight="{Binding TableRowHeight}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Vybrat" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                            <DataGridTextColumn Header="Číslo" Binding="{Binding Number}" Width="120" IsReadOnly="True" />
                            <DataGridTextColumn Header="Datum" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="110" IsReadOnly="True" />
                            <DataGridTextColumn Header="Stav" Binding="{Binding Status}" Width="120" IsReadOnly="True" />
                            <DataGridTextColumn Header="Název" Binding="{Binding Title}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Celkem" Binding="{Binding TotalAmount, StringFormat=F0}" Width="120" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock DockPanel.Dock="Left" Text="Dvojklik v seznamu otevře editaci faktury." VerticalAlignment="Center" Foreground="Gray" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Nová faktura"
                        Command="{Binding StartNewInvoiceCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Visibility="{Binding IsListStep, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Button Content="Zpět"
                        Command="{Binding BackToListCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsCreateStep, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="Vytvořit a otevřít editaci"
                        Command="{Binding NextStepCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Visibility="{Binding IsCreateStep, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Button Content="Zpět na seznam"
                        Command="{Binding BackToListCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsEditStep, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="{Binding EditSaveButtonText}"
                        Command="{Binding SaveAndBackToListCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsEditStep, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="PDF"
                        Command="{Binding ExportPdfCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsEditStep, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="CSV"
                        Command="{Binding ExportCsvCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Visibility="{Binding IsEditStep, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </DockPanel>
    </Grid>
    </Border>
</UserControl>
