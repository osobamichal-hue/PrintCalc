<Window x:Class="PrintCalc.App.Views.CustomerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editace zákazníka"
        Width="560"
        Height="470"
        WindowStartupLocation="CenterOwner"
        MinWidth="480"
        MinHeight="360"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Height="52" CornerRadius="12" Padding="12,0" Margin="0,0,0,10" Background="#FFF7F9FF" BorderBrush="#FFDDE5FF" BorderThickness="1">
            <DockPanel>
                <TextBlock Text="Editace zákazníka" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16" />
            </DockPanel>
        </Border>
        <Border Grid.Row="1" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Text="Název zákazníka *" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                <TextBlock Text="IČ" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding CompanyId, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Text="DIČ" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding VatId, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                <TextBlock Text="Ulice" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Street, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Text="Město" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                <TextBlock Text="PSČ" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Zip, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Text="E-mail" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                <TextBlock Text="Telefon" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Splatnost (dny)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding InvoiceDueDays, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,0">
                <TextBlock Text="Výchozí platba" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding PreferredPaymentMethod, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Storno" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
            <Button Content="Uložit změny" IsDefault="True" Click="Save_OnClick" />
        </StackPanel>
    </Grid>
</Window>

