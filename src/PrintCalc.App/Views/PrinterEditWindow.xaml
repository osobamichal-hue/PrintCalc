<Window x:Class="PrintCalc.App.Views.PrinterEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:PrintCalc.Core.Enums;assembly=PrintCalc.Core"
        Title="Editace tiskárny"
        Width="560"
        Height="430"
        WindowStartupLocation="CenterOwner"
        MinWidth="480"
        MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Window.Resources>
        <x:Array x:Key="PrinterKindValues" Type="enums:PrinterKind">
            <enums:PrinterKind>Fff</enums:PrinterKind>
            <enums:PrinterKind>Sla</enums:PrinterKind>
        </x:Array>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Height="52" CornerRadius="12" Padding="12,0" Margin="0,0,0,10" Background="#FFF7F9FF" BorderBrush="#FFDDE5FF" BorderThickness="1">
            <TextBlock Text="Editace tiskárny" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16" />
        </Border>
        <Border Grid.Row="1" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Text="Název *" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                <TextBlock Text="Typ" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox ItemsSource="{StaticResource PrinterKindValues}" SelectedItem="{Binding Kind}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Style="{StaticResource FieldLabelStyle}">
                    <Run Text="Hodinovka stroje (Kč/h)" />
                    <Run Text=" " />
                    <Run Text="(i)" ToolTip="Souhrnná sazba za provoz stroje včetně odpisu/amortizace a režie, které nechcete mít zvlášť. Spotřeba elektřiny se v kalkulaci dopočítává z kWh/h a ceny kWh." FontSize="11" Foreground="#666" />
                </TextBlock>
                <TextBox Text="{Binding HourlyRate, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                <TextBlock Text="Spotřeba (kWh/h)" Style="{StaticResource FieldLabelStyle}"
                           ToolTip="Průměrný odběr tiskárny za hodinu čistého tisku; použije se k nákladům na elektřinu." />
                <TextBox Text="{Binding KwhPerHour, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Text="Poplatek/tisk (Kč)" Style="{StaticResource FieldLabelStyle}"
                           ToolTip="Pevná částka za každé zahájení tisku (nahřátí, příprava podložky…), násobí se počtem tisků." />
                <TextBox Text="{Binding StartFeePerPrint, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                <TextBlock Text="Max. objem" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding MaxVolumeDescription, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                <TextBlock Text="Poznámka" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Storno" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
            <Button Content="Uložit změny" IsDefault="True" Click="Save_OnClick" />
        </StackPanel>
    </Grid>
</Window>

