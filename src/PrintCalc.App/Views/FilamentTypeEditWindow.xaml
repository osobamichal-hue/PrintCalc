<Window x:Class="PrintCalc.App.Views.FilamentTypeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editace skladové karty filamentu"
        Width="680"
        Height="430"
        WindowStartupLocation="CenterOwner"
        MinWidth="480"
        MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Height="52" CornerRadius="12" Padding="12,0" Margin="0,0,0,10" Background="#FFF7F9FF" BorderBrush="#FFDDE5FF" BorderThickness="1">
            <TextBlock Text="Editace skladové karty filamentu" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16" />
        </Border>
        <Border Grid.Row="1" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Text="Typ (PLA/PET-G/ASA...)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8">
                <TextBlock Text="Výrobce" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Manufacturer, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                <TextBlock Text="Barva" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Text="Průměr (mm)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding DiameterMm, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,8">
                <TextBlock Text="Hustota (g/cm3)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding DensityGPerCm3, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <Grid Grid.Row="1" Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="Tryska min/max (°C)" Style="{StaticResource FieldLabelStyle}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="60" Margin="0,0,6,0" Text="{Binding NozzleTempMinC, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="60" Text="{Binding NozzleTempMaxC, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,0,8">
                    <TextBlock Text="Bed min/max (°C)" Style="{StaticResource FieldLabelStyle}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="60" Margin="0,0,6,0" Text="{Binding BedTempMinC, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="60" Text="{Binding BedTempMaxC, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                <TextBlock Text="Poznámky ke kartě" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Storno" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
            <Button Content="Uložit změny" IsDefault="True" Click="Save_OnClick" />
        </StackPanel>
    </Grid>
</Window>

