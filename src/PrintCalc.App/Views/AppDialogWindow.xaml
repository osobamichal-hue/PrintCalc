<Window x:Class="PrintCalc.App.Views.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500"
        Height="260"
        MinWidth="420"
        MinHeight="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Title="{Binding TitleText, RelativeSource={RelativeSource Self}}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#EEF2FF" BorderBrush="#D4DBF2" BorderThickness="1" Padding="12,8" CornerRadius="10">
            <StackPanel>
                <TextBlock Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="SemiBold" FontSize="16" />
                <TextBlock Text="{Binding ToneText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#5B6180" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,10,0,10" VerticalScrollBarVisibility="Auto">
            <TextBlock Text="{Binding MessageText, RelativeSource={RelativeSource AncestorType=Window}}" TextWrapping="Wrap" FontSize="14" />
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="YesOkButton" Content="OK" Width="108" Margin="0,0,8,0" Click="YesOkButton_Click" />
            <Button x:Name="NoButton" Content="Ne" Width="108" Margin="0,0,8,0" Click="NoButton_Click" />
            <Button x:Name="CancelButtonEx" Content="Storno" Width="108" Click="CancelButtonEx_Click" />
        </StackPanel>
    </Grid>
</Window>

