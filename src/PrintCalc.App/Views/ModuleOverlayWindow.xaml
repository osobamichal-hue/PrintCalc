<Window x:Class="PrintCalc.App.Views.ModuleOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1240"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid>
        <Border Margin="10" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="14" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Height="56" CornerRadius="12" Padding="14,0" Margin="0,0,0,10" Background="#FFF7F9FF" BorderBrush="#FFDDE5FF" BorderThickness="1">
                    <DockPanel LastChildFill="False">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="#FF5B43D6" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding HeaderTitle, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="18" FontWeight="SemiBold" Foreground="#FF221A44" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="{Binding SaveButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Command="{Binding SaveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SaveCommand, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Zavřít" Click="Close_OnClick" Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ContentPresenter Grid.Row="1" Content="{Binding OverlayContent, RelativeSource={RelativeSource AncestorType=Window}}" />
            </Grid>
        </Border>
    </Grid>
</Window>

