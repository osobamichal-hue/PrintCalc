<UserControl x:Class="PrintCalc.App.Views.QuotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:PrintCalc.App.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:NullableCalculationIdToLabelConverter x:Key="CalcGroupLabelConverter" />
        <Style x:Key="CompactActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0" />
        </Style>
    </UserControl.Resources>
    <Border Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource WizardHeaderBorderStyle}">
            <TextBlock Style="{StaticResource WizardHeaderTextStyle}" Text="Nabídky: vyberte a dvojklikem otevřete k editaci." />
        </Border>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left" Text="{Binding WizardStepTitle}" FontWeight="SemiBold" VerticalAlignment="Center" />
            <CheckBox DockPanel.Dock="Right" Content="Kompaktní tabulky" IsChecked="{Binding CompactTables}" VerticalAlignment="Center" Margin="24,0,0,0" />
        </DockPanel>

        <TabControl Grid.Row="2" SelectedIndex="{Binding WizardStepIndex}" Style="{StaticResource WizardTabControlStyle}">
            <TabItem Header="1) Seznam nabídek">
                <Grid Margin="0,6,0,0">
                    <DataGrid x:Name="QuotesGrid"
                              ItemsSource="{Binding Quotes}"
                              SelectedItem="{Binding SelectedQuote}"
                              RowHeight="{Binding TableRowHeight}"
                              AutoGenerateColumns="False"
                              MouseDoubleClick="QuotesGrid_OnMouseDoubleClick"
                              Margin="0">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Otevřít k editaci" Command="{Binding PlacementTarget.DataContext.OpenSelectedForEditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Uložit nabídku" Command="{Binding PlacementTarget.DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Schválit nabídku" Command="{Binding PlacementTarget.DataContext.ApproveSelectedQuoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Exportovat PDF" Command="{Binding PlacementTarget.DataContext.ExportSelectedPdfCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Smazat nabídku" Command="{Binding PlacementTarget.DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Číslo" Binding="{Binding Number}" Width="120" IsReadOnly="True" />
                            <DataGridTextColumn Header="Název" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            <DataGridTemplateColumn Header="Stav" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status, Converter={StaticResource DocumentStatusToBrushConverter}}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Datum" Binding="{Binding IssueDate, StringFormat=yyyy-MM-dd}" Width="120" IsReadOnly="True" />
                            <DataGridTextColumn Header="Celkem" Binding="{Binding TotalAmount, StringFormat=F0}" Width="120" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Background="#DFFFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="16"
                            Visibility="{Binding ElementName=QuotesGrid, Path=HasItems, Converter={StaticResource BooleanInvertedToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Žádné nabídky" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="Vytvořte první nabídku tlačítkem Nová nabídka." Foreground="Gray" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="2) Položky vybrané nabídky">
                <DockPanel Margin="0,6,0,0">
                    <Border DockPanel.Dock="Top" BorderBrush="#33000000" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                        <WrapPanel>
                            <TextBlock Text="Číslo:" FontWeight="SemiBold" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding SelectedQuote.Number}" Margin="0,0,16,0" />
                            <TextBlock Text="Název:" FontWeight="SemiBold" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding SelectedQuote.Title}" Margin="0,0,16,0" />
                            <TextBlock Text="Celkem:" FontWeight="SemiBold" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding SelectedQuote.TotalAmount, StringFormat=F0}" />
                            <Button Content="Řádek nabídky" Command="{Binding AddLineCommand}" Style="{StaticResource CompactActionButtonStyle}" Margin="12,0,8,0" />
                            <Button Content="Schválit nabídku" Command="{Binding ApproveSelectedQuoteCommand}" Style="{StaticResource CompactActionButtonStyle}" Margin="0,0,8,0" />
                            <Button Content="Tisk/Export PDF" Command="{Binding ExportSelectedPdfCommand}" Style="{StaticResource CompactActionButtonStyle}" />
                        </WrapPanel>
                    </Border>
                    <GroupBox DockPanel.Dock="Top" Header="Přidat položku (formulář)" Margin="0,0,0,8">
                        <WrapPanel Margin="0,4,0,0">
                            <TextBlock Text="Popis:" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Width="300" Text="{Binding NewLineDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                            <TextBlock Text="Množství:" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Width="90" Text="{Binding NewLineQuantity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                            <TextBlock Text="Cena/j.:" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Width="110" Text="{Binding NewLineUnitPrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                            <Button Content="Uložit položku" Command="{Binding AddLineCommand}" Style="{StaticResource CompactActionButtonStyle}" />
                        </WrapPanel>
                    </GroupBox>

                    <TextBlock DockPanel.Dock="Top"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Text="Řádky se stejným číslem v „Kalk.“ a stejným podbarvením patří k jedné kalkulaci (obvykle modelování + 3D tisk). U ručně přidaných položek je v „Kalk.“ pomlčka." />

                    <DataGrid x:Name="QuoteLinesGrid"
                              ItemsSource="{Binding SelectedQuote.Lines}"
                              SelectedItem="{Binding SelectedQuoteLine}"
                              RowHeight="{Binding TableRowHeight}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              LoadingRow="QuoteLinesGrid_OnLoadingRow">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Přidat řádek" Command="{Binding PlacementTarget.DataContext.AddLineCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Odebrat řádek" Command="{Binding PlacementTarget.DataContext.RemoveSelectedQuoteLineCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Přepočítat a uložit" Command="{Binding PlacementTarget.DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Kalk." Width="64">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6"
                                                Padding="6,2"
                                                Margin="0,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="#E8E0F4">
                                            <TextBlock FontWeight="SemiBold"
                                                       FontSize="11"
                                                       Foreground="#4A3780"
                                                       Text="{Binding SourceCalculationId, Converter={StaticResource CalcGroupLabelConverter}}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Popis" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                            <DataGridTextColumn Header="Množ." Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                            <DataGridTextColumn Header="Cena/j." Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                            <DataGridTextColumn Header="Řádek" Binding="{Binding LineTotal, StringFormat=F0}" Width="120" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="3) Výběr kalkulací do nabídky">
                <DockPanel Margin="0,6,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Vytvořit nabídku z vybraných kalkulací"
                                Command="{Binding CreateFromSelectedCalculationsCommand}"
                                Style="{StaticResource CompactActionButtonStyle}"
                                Margin="0,0,8,0" />
                        <CheckBox Content="Detailní kalkulace pro zákazníka"
                                  IsChecked="{Binding CreateAsDetailedCalculation}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0" />
                        <TextBlock VerticalAlignment="Center" Text="(držte Ctrl/Shift pro vícevýběr)" Foreground="Gray" />
                    </StackPanel>
                    <DataGrid x:Name="CalcSelectionGrid"
                              ItemsSource="{Binding AvailableCalculations}"
                              RowHeight="{Binding TableRowHeight}"
                              AutoGenerateColumns="False"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              CanUserAddRows="False"
                              SelectionChanged="CalcSelectionGrid_OnSelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Datum" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="160" />
                            <DataGridTextColumn Header="Název kalkulace" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="Celkem" Binding="{Binding TotalWithMargin, StringFormat=F0}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock DockPanel.Dock="Left" Text="Dvojklik v seznamu otevře editaci nabídky." VerticalAlignment="Center" Foreground="Gray" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Nová nabídka"
                        Command="{Binding StartNewQuoteCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Visibility="{Binding IsListStep, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Button Content="Zpět"
                        Command="{Binding BackToListCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsCreateStep, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="Vytvořit a otevřít editaci"
                        Command="{Binding NextStepCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Visibility="{Binding IsCreateStep, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Button Content="Zpět na seznam"
                        Command="{Binding BackToListCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsEditStep, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="{Binding EditSaveButtonText}"
                        Command="{Binding SaveAndBackToListCommand}"
                        Style="{StaticResource WizardNavButtonStyle}"
                        Visibility="{Binding IsEditStep, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </DockPanel>
    </Grid>
    </Border>
</UserControl>
