<Window x:Class="PrintCalc.App.Views.InvoicePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Náhled faktury"
        WindowStartupLocation="CenterOwner"
        Width="980"
        Height="680">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{Binding AccentBrush}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding HeaderText}" FontSize="30" Foreground="White" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SubHeaderText}" Foreground="#EAF3FF" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StyleLabel, StringFormat=Styl: {0}}" Foreground="#DDEEFF" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding TotalAmountBig}"
                           VerticalAlignment="Center"
                           FontSize="28"
                           Foreground="White"
                           FontWeight="Bold"
                           Visibility="{Binding IsAurora, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Margin="0,0,12,0" Padding="10" Background="{Binding AccentSoftBrush}">
                <StackPanel>
                    <Grid Width="100" Height="100" HorizontalAlignment="Center" Margin="0,0,0,12"
                          Visibility="{Binding LogoAreaVisibility}">
                        <Border BorderBrush="#555" BorderThickness="1" />
                        <Image Source="{Binding LogoPath}" Stretch="Uniform" Margin="6" Visibility="{Binding LogoVisibility}" />
                    </Grid>
                    <TextBlock Text="DODAVATEL" FontWeight="Bold" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding SupplierText}" TextWrapping="Wrap" />
                    <TextBlock Text=" " Margin="0,8,0,0" />
                    <TextBlock Text="{Binding PaymentMethodText}" />
                    <TextBlock Text="{Binding VariableSymbolText}" />
                    <TextBlock Text="{Binding BankAccountText}" />
                    <TextBlock Text="{Binding IbanText}" />
                    <TextBlock Text="{Binding SwiftText}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Padding="8" Background="{Binding AccentDarkBrush}"
                    Visibility="{Binding IsPhoenix, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding IntroText}" Foreground="White" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="{Binding TotalText}" Foreground="White" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" BorderThickness="1" BorderBrush="#22000000" Padding="8" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding DateText}" />
                        <TextBlock Text="{Binding DueText}" />
                        <TextBlock Text="{Binding TaxDateText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="ODBĚRATEL" FontWeight="Bold" />
                        <TextBlock Text="{Binding CustomerText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid Grid.Row="2" Grid.Column="1"
                      ItemsSource="{Binding Lines}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="POLOŽKA" Binding="{Binding Description}" Width="*" />
                    <DataGridTextColumn Header="DPH %" Binding="{Binding TaxRatePercent, StringFormat=0}" Width="80" />
                    <DataGridTextColumn Header="CENA ZA MJ" Binding="{Binding UnitPrice, StringFormat=F2}" Width="120" />
                    <DataGridTextColumn Header="MNOŽSTVÍ" Binding="{Binding Quantity, StringFormat=0.##}" Width="100" />
                    <DataGridTextColumn Header="CELKEM BEZ DPH" Binding="{Binding LineTotal, StringFormat=F2}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Margin="0,8,0,0">
                <TextBlock Text="{Binding SummaryTitle}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                <TextBlock Text="{Binding NetText}" />
                <TextBlock Text="{Binding VatText}" />
                <TextBlock Text="{Binding TotalText}" FontWeight="Bold" FontSize="15" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12">
            <Button Content="Zavřít" IsCancel="True" Padding="12,6" Margin="0,0,8,0" />
            <Button Content="{Binding ConfirmButtonText}"
                    IsDefault="True"
                    Padding="12,6"
                    Click="Export_OnClick"
                    Visibility="{Binding ConfirmButtonVisibility}" />
        </StackPanel>
    </Grid>
</Window>
