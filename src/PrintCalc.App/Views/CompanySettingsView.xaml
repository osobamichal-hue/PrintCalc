<UserControl x:Class="PrintCalc.App.Views.CompanySettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PrintCalc.App.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <converters:DecimalFieldConverter x:Key="DecimalFieldConverter" />
    </UserControl.Resources>
    <Grid MaxWidth="980">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource WizardHeaderBorderStyle}" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource WizardHeaderTextStyle}" Text="Nastavení aplikace - firma, vzhled, výstupy, finance" />
        </Border>

        <Border Grid.Row="1" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="8">
        <TabControl>
            <TabItem Header="Firma">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Text="Název firmy" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                        <TextBlock Text="Adresa" />
                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="IČO" />
                                <TextBox Text="{Binding Ico, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="DIČ" />
                                <TextBox Text="{Binding Dic, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="E-mail" />
                                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="Telefon" />
                                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="IBAN" />
                                <TextBox Text="{Binding Iban, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="SWIFT (BIC)" />
                                <TextBox Text="{Binding Swift, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Číslo účtu" />
                                <TextBox Text="{Binding BankAccount, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="Způsob úhrady" />
                                <TextBox Text="{Binding PaymentMethod, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="Logo firmy (soubor)" />
                        <DockPanel Margin="0,4,0,8">
                            <Button Content="Vybrat logo..." Command="{Binding BrowseLogoCommand}" Padding="10,4" DockPanel.Dock="Right" Margin="8,0,0,0" />
                            <TextBox Text="{Binding LogoPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Aplikace">
                <StackPanel Margin="8">
                    <TextBlock Text="Vzhled aplikace (Windows 11)" />
                    <ComboBox ItemsSource="{Binding AppThemes}" SelectedItem="{Binding AppTheme}" Margin="0,4,0,8" />
                    <TextBlock Text="Barevná paleta (moderní pastelové tóny)" />
                    <ComboBox ItemsSource="{Binding ColorPalettes}" SelectedItem="{Binding ColorPalette}" Margin="0,4,0,8" />
                    <TextBlock Text="Datová složka aplikace (zálohy, výchozí exporty)" />
                    <DockPanel Margin="0,4,0,8">
                        <Button Content="Změnit..." Command="{Binding BrowseDataRootCommand}" Padding="10,4" DockPanel.Dock="Right" Margin="8,0,0,0" />
                        <TextBox Text="{Binding DataRootPath, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <TextBlock Text="Tip: pokud necháte exportní složky prázdné, použije se datová složka + podsložky." Foreground="Gray" />

                    <GroupBox Header="Výchozí režim převodu dokladů" Margin="0,16,0,0" Padding="8">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,8"
                                       Text="Stejné volby jako v modulech Nabídky, Zakázky a Faktury. Změna se uloží hned; při návratu do modulu se načte aktuální hodnota." />
                            <CheckBox Content="Nabídky: detailní kalkulace z výběru kalkulací (modelování + tisk na kusy)"
                                      IsChecked="{Binding DefaultQuotesDetailedFromCalculation}" Margin="0,0,0,6" />
                            <CheckBox Content="Zakázky: detailní převod položek z nabídek"
                                      IsChecked="{Binding DefaultOrdersDetailedFromQuotes}" Margin="0,0,0,6" />
                            <CheckBox Content="Faktury: detailní převod položek ze zakázek"
                                      IsChecked="{Binding DefaultInvoicesDetailedFromOrders}" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <TabItem Header="Šablony a výstupy">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Text="Šablona dokumentů (PDF styl)" />
                        <ComboBox ItemsSource="{Binding DocumentVisualStyles}" SelectedItem="{Binding DocumentVisualStyle}" Margin="0,4,0,8" />

                        <TextBlock Text="Export PDF kalkulací" />
                        <DockPanel Margin="0,4,0,8">
                            <Button Content="Změnit..." Command="{Binding BrowseExportCalculationsCommand}" Padding="10,4" DockPanel.Dock="Right" Margin="8,0,0,0" />
                            <TextBox Text="{Binding ExportCalculationsPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TextBlock Text="Export PDF nabídek" />
                        <DockPanel Margin="0,4,0,8">
                            <Button Content="Změnit..." Command="{Binding BrowseExportQuotesCommand}" Padding="10,4" DockPanel.Dock="Right" Margin="8,0,0,0" />
                            <TextBox Text="{Binding ExportQuotesPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TextBlock Text="Export PDF faktur" />
                        <DockPanel Margin="0,4,0,8">
                            <Button Content="Změnit..." Command="{Binding BrowseExportInvoicesPdfCommand}" Padding="10,4" DockPanel.Dock="Right" Margin="8,0,0,0" />
                            <TextBox Text="{Binding ExportInvoicesPdfPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TextBlock Text="Export CSV faktur" />
                        <DockPanel Margin="0,4,0,8">
                            <Button Content="Změnit..." Command="{Binding BrowseExportInvoicesCsvCommand}" Padding="10,4" DockPanel.Dock="Right" Margin="8,0,0,0" />
                            <TextBox Text="{Binding ExportInvoicesCsvPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Finance">
                <StackPanel Margin="8">
                    <TextBlock Text="Výchozí měna" />
                    <ComboBox ItemsSource="{Binding CurrencyCodes}" SelectedItem="{Binding DefaultCurrencyCode}" Margin="0,4,0,8" />
                    <TextBlock Text="Symbol měny" />
                    <TextBox Text="{Binding DefaultCurrencySymbol, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                    <TextBlock Text="Prefix číselné řady faktur (např. FA)" />
                    <TextBox Text="{Binding InvoiceNumberPrefix, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                    <TextBlock Text="Dostupné řady pro výběr při tvorbě FA (oddělte čárkou nebo středníkem)" />
                    <TextBox Text="{Binding InvoiceNumberSeriesList, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                    <CheckBox Content="Použít oddělovač mezi prefixem a pořadovým číslem (-)"
                              IsChecked="{Binding InvoiceNumberUseSeparator}"
                              Margin="0,0,0,8" />
                    <TextBlock Text="Počet číslic pořadového čísla (1-3)" />
                    <ComboBox SelectedValue="{Binding InvoiceNumberCounterDigits}"
                              SelectedValuePath="Tag"
                              Margin="0,4,0,8">
                        <ComboBoxItem Content="1" Tag="1" />
                        <ComboBoxItem Content="2" Tag="2" />
                        <ComboBoxItem Content="3" Tag="3" />
                    </ComboBox>
                    <TextBlock Foreground="Gray"
                               Margin="0,0,0,8"
                               Text="Příklady: prefix 2026 + bez oddělovače + 3 číslice => 2026001. Pro další číselnou řadu stačí změnit prefix (např. FA, ESHOP, 2027)." />
                    <TextBlock Text="Výchozí DPH (%)" />
                    <TextBox Margin="0,4,0,8">
                        <TextBox.Text>
                            <Binding Path="DefaultVatRatePercent" Converter="{StaticResource DecimalFieldConverter}" UpdateSourceTrigger="LostFocus" />
                        </TextBox.Text>
                    </TextBox>
                </StackPanel>
            </TabItem>
        </TabControl>
        </Border>

        <StackPanel Grid.Row="2">
            <Border Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Margin="0">
                <Button Content="Uložit" Command="{Binding SaveCommand}" Padding="12,6" Margin="0,0,8,0" />
                <Button Content="Obnovit" Command="{Binding RefreshCommand}" Padding="12,6" />
                <Button Content="Vytvořit zálohu" Command="{Binding BackupNowCommand}" Padding="12,6" Margin="8,0,0,0" />
                <Button Content="Obnovit ze zálohy" Command="{Binding RestoreFromBackupCommand}" Padding="12,6" Margin="8,0,0,0" />
            </StackPanel>
            </Border>
            <materialDesign:Snackbar Margin="0,8,0,0"
                                     Message="{Binding StatusMessage}"
                                     IsActive="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToBoolConverter}}" />
        </StackPanel>
    </Grid>
</UserControl>
