<Window x:Class="PrintCalc.App.Views.IssueStockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PrintCalc.App.Converters"
        Title="Výdej ze skladu"
        Width="560"
        Height="420"
        MinWidth="420"
        MinHeight="320"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:DecimalFieldConverter x:Key="DecimalFieldConverter" />
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <Expander Header="Karta 1/2 - Údaje výdeje" IsExpanded="True" Margin="0,0,0,8">
                <StackPanel Margin="8">
                    <TextBlock Text="Množství (kg)" />
                    <TextBox Margin="0,4,0,8">
                        <TextBox.Text>
                            <Binding Path="IssueWeightKg" Converter="{StaticResource DecimalFieldConverter}" UpdateSourceTrigger="LostFocus" />
                        </TextBox.Text>
                    </TextBox>
                    <TextBlock Text="Zakázka / reference" />
                    <TextBox Text="{Binding IssueOrderReference, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                    <TextBlock Text="Poznámka výdeje" />
                    <TextBox Text="{Binding IssueNote, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                </StackPanel>
            </Expander>
            <Expander Header="Karta 2/2 - Potvrzení" IsExpanded="True">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding SelectedType.Name, StringFormat=Typ: {0}}" />
                    <TextBlock Text="{Binding IssueWeightKg, StringFormat=Výdej: {0:F3} kg}" />
                    <TextBlock Text="{Binding IssueOrderReference, StringFormat=Zakázka: {0}}" />
                </StackPanel>
            </Expander>
        </StackPanel>
        <WrapPanel Grid.Row="1" Margin="0,10,0,0">
            <Button Content="Potvrdit výdej ze skladu" Padding="12,6" Margin="0,0,8,0" Click="ConfirmIssue_OnClick" />
            <Button Content="Zavřít" Padding="12,6" Click="Close_OnClick" />
        </WrapPanel>
    </Grid>
</Window>
