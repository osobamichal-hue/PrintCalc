<Window x:Class="PrintCalc.App.Views.NewInvoiceFromOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nová faktura ze zakázek"
        WindowStartupLocation="CenterOwner"
        Width="760"
        Height="560"
        MinWidth="640"
        MinHeight="460"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Vyberte jednu nebo více zakázek pro vytvoření faktury." FontWeight="SemiBold" />
            <CheckBox Content="Převést detailně (zachovat položky zakázek)"
                      IsChecked="{Binding CreateAsDetailedFromOrders}"
                      Margin="0,6,0,0" />
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="Vybrat vše" Padding="10,4" Margin="0,0,8,0" Click="SelectAll_OnClick" />
                <Button Content="Zrušit výběr" Padding="10,4" Margin="0,0,8,0" Click="ClearSelection_OnClick" />
                <TextBlock VerticalAlignment="Center" Text="{Binding SelectedCountText}" FontWeight="SemiBold" />
            </StackPanel>
        </StackPanel>
        <DataGrid x:Name="OrderGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Vybrat" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                <DataGridTextColumn Header="Číslo" Binding="{Binding Number}" Width="120" />
                <DataGridTextColumn Header="Datum" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="110" />
                <DataGridTextColumn Header="Stav" Binding="{Binding Status}" Width="110" />
                <DataGridTextColumn Header="Název" Binding="{Binding Title}" Width="*" />
                <DataGridTextColumn Header="Celkem" Binding="{Binding Total, StringFormat=F2}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="2" BorderThickness="1,0,0,0" BorderBrush="#33000000" Padding="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Zrušit" IsCancel="True" Padding="12,6" Margin="0,0,8,0" />
                <Button Content="Potvrdit výběr a přenést do faktury" IsDefault="True" Padding="12,6" Click="Create_OnClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
