<UserControl x:Class="PrintCalc.App.Views.PrintersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:PrintCalc.Core.Enums;assembly=PrintCalc.Core"
             xmlns:converters="clr-namespace:PrintCalc.App.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Language="cs-CZ">
    <UserControl.Resources>
        <converters:DecimalFieldConverter x:Key="DecimalFieldConverter" />
        <x:Array x:Key="PrinterKindValues" Type="enums:PrinterKind">
            <enums:PrinterKind>Fff</enums:PrinterKind>
            <enums:PrinterKind>Sla</enums:PrinterKind>
        </x:Array>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F4F8FF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12,10" Margin="0,0,0,10">
            <TextBlock Text="Tiskárny" FontSize="18" FontWeight="SemiBold" />
        </Border>

        <Border Grid.Row="1" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,10">
        <GroupBox Header="Přidat / upravit tiskárnu" Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,6">
                    <TextBlock Text="Název *" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,6">
                    <TextBlock Text="Typ" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox ItemsSource="{StaticResource PrinterKindValues}"
                              SelectedItem="{Binding NewKind}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,6">
                    <TextBlock Text="Max. objem" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding NewMaxVolumeDescription, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}">
                        <Run Text="Hodinovka (Kč/h)" />
                        <Run Text=" " />
                        <Run Text="(i)" ToolTip="Provoz + odpis stroje v jedné sazbě; energie zvlášť přes kWh/h." FontSize="11" Foreground="#666" />
                    </TextBlock>
                    <TextBox Text="{Binding NewHourlyRate, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="kWh/h" Style="{StaticResource FieldLabelStyle}"
                               ToolTip="Spotřeba za hodinu tisku pro výpočet elektřiny." />
                    <TextBox Text="{Binding NewKwhPerHour, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Poplatek/tisk (Kč)" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding NewStartFeePerPrint, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" VerticalAlignment="Bottom">
                    <Button Content="Uložit novou" Command="{Binding AddCommand}" Margin="0,0,0,8" Padding="12,6" />
                    <Button Content="Vyčistit" Command="{Binding ClearFormCommand}" Padding="12,6" Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </GroupBox>
        </Border>

        <Border Grid.Row="2" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,10">
        <WrapPanel Margin="0">
            <Button Content="Uložit změny" Command="{Binding SaveCommand}" Margin="0,0,8,0" Padding="12,6" />
            <Button Content="Obnovit seznam" Command="{Binding RefreshCommand}" Padding="12,6" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" />
            <Button Content="Smazat vybranou" Command="{Binding DeleteCommand}" Padding="12,6" Style="{StaticResource DangerButtonStyle}" />
        </WrapPanel>
        </Border>
        <Border Grid.Row="3" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="8">
        <DataGrid ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedPrinter}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  MouseDoubleClick="PrintersGrid_OnMouseDoubleClick">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Přidat" Command="{Binding AddCommand}" />
                    <MenuItem Header="Editovat" Click="EditPrinter_OnClick" />
                    <MenuItem Header="Uložit" Command="{Binding SaveCommand}" />
                    <MenuItem Header="Smazat" Command="{Binding DeleteCommand}" />
                    <MenuItem Header="Obnovit" Command="{Binding RefreshCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Název" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                <DataGridComboBoxColumn Header="Typ"
                                        SelectedItemBinding="{Binding Kind, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{StaticResource PrinterKindValues}" />
                <DataGridTextColumn Header="Kč/h (stroj)" Width="100">
                    <DataGridTextColumn.Binding>
                        <Binding Path="HourlyRate"
                                 Converter="{StaticResource DecimalFieldConverter}"
                                 UpdateSourceTrigger="LostFocus" />
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="kWh/h" Width="90">
                    <DataGridTextColumn.Binding>
                        <Binding Path="KwhPerHour"
                                 Converter="{StaticResource DecimalFieldConverter}"
                                 UpdateSourceTrigger="LostFocus" />
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Poplatek/tisk (Kč)" Width="120">
                    <DataGridTextColumn.Binding>
                        <Binding Path="StartFeePerPrint"
                                 Converter="{StaticResource DecimalFieldConverter}"
                                 UpdateSourceTrigger="LostFocus" />
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Max. objem" Binding="{Binding MaxVolumeDescription, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                <DataGridTextColumn Header="Poznámka" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
        </Border>
        <materialDesign:Snackbar Grid.Row="4"
                                 Margin="0,8,0,0"
                                 Message="{Binding StatusMessage}"
                                 IsActive="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToBoolConverter}}" />
    </Grid>
</UserControl>
