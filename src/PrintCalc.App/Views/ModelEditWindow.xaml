<Window x:Class="PrintCalc.App.Views.ModelEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editace modelu"
        Width="560"
        Height="380"
        WindowStartupLocation="CenterOwner"
        MinWidth="480"
        MinHeight="360"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Height="52" CornerRadius="12" Padding="12,0" Margin="0,0,0,10" Background="#FFF7F9FF" BorderBrush="#FFDDE5FF" BorderThickness="1">
            <TextBlock Text="Editace modelu" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16" />
        </Border>
        <Border Grid.Row="1" Background="#FFFFFFFF" BorderBrush="#E2E7F6" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                <TextBlock Text="Název modelu *" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                <TextBlock Text="Odhad materiálu (g)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding EstimatedMaterialGrams, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                <TextBlock Text="Odhad tisku (h)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding EstimatedPrintHours, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                <TextBlock Text="Poznámka" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Storno" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
            <Button Content="Uložit změny" IsDefault="True" Click="Save_OnClick" />
        </StackPanel>
    </Grid>
</Window>

